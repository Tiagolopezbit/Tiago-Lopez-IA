        "from mistralai.client import MistralClient # Corrección: Cambiar importación y clase\n",
        "\n",
        "class BotRAGMistral:\n",
        "    \"\"\"\n",
        "    Bot RAG que usa:\n",
        "      - sentence-transformers + FAISS  → Recuperación de contexto\n",
        "      - Mistral AI (mistral-small)     → Generación de respuestas\n",
        "\n",
        "    Flujo por pregunta:\n",
        "      1. Embed pregunta\n",
        "      2. Buscar top-k docs en FAISS\n",
        "      3. Construir prompt con contexto\n",
        "      4. Llamar a Mistral API\n",
        "      5. Retornar respuesta\n",
        "    \"\"\"\n",
        "\n",
        "    def __init__(self, corpus, index, modelo_embed, df, api_key, top_k=4,\n",
        "                 modelo_mistral='mistral-small-latest'):\n",
        "        self.corpus        = corpus\n",
        "        self.index         = index\n",
        "        self.modelo_embed  = modelo_embed\n",
        "        self.df            = df\n",
        "        self.top_k         = top_k\n",
        "        self.modelo_mistral = modelo_mistral\n",
        "        self.client        = MistralClient(api_key=api_key) # Corrección: Instanciar MistralClient\n",
        "        self.historial     = []   # conversación multi-turno\n",
        "\n",
        "        # System prompt con contexto del negocio\n",
        "        total = df['total_venta'].sum() if 'total_venta' in df.columns else 0\n",
        "        productos = df['producto'].nunique() if 'producto' in df.columns else 0\n",
        "        self.system_prompt = (\n",
        "            f\"Eres un asistente de análisis de ventas experto y amigable. \"\n",
        "            f\"Tienes acceso a una base de datos con {len(df)} registros de ventas, \"\n",
        "            f\"{productos} productos distintos e ingresos totales de ${total:,.2f}. \"\n",
        "            f\"Responde siempre en español, de forma clara y concisa. \"\n",
        "            f\"Usa los datos del contexto proporcionado para responder con precisión. \"\n",
        "            f\"Si el contexto no es suficiente, indícalo honestamente.\"\n",
        "        )\n",
        "\n",
        "    def recuperar_contexto(self, pregunta):\n",
        "        \"\"\"Busca los documentos más similares en FAISS\"\"\"\n",
        "        q_emb = self.modelo_embed.encode([pregunta]).astype('float32')\n",
        "        distancias, indices = self.index.search(q_emb, self.top_k)\n",
        "        docs = [self.corpus[i] for i in indices[0]]\n",
        "        return docs, distancias[0]\n",
        "\n",
        "    def construir_prompt(self, pregunta, docs):\n",
        "        \"\"\"Arma el mensaje usuario con contexto RAG incrustado\"\"\"\n",
        "        contexto = '\\n'.join([f'  {i+1}. {d}' for i, d in enumerate(docs)])\n",
        "        return (\n",
        "            f\"CONTEXTO RELEVANTE (recuperado de los datos):\\n{contexto}\\n\\n\"\n",
        "            f\"PREGUNTA: {pregunta}\"\n",
        "        )\n",
        "\n",
        "    def preguntar(self, pregunta, verbose=True):\n",
        "        \"\"\"Hace una pregunta al bot y retorna la respuesta de Mistral\"\"\"\n",
        "        if verbose:\n",
        "            print(f\"\\n{'='*60}\")\n",
        "            print(f'❓ {pregunta}')\n",
        "            print('='*60)\n",
        "\n",
        "        # 1. Recuperar contexto relevante\n",
        "        docs, distancias = self.recuperar_contexto(pregunta)\n",
        "\n",
        "        if verbose:\n",
        "            print(f'\\n📚 Contexto recuperado (top {self.top_k}):')\n",
        "            for i, (doc, dist) in enumerate(zip(docs, distancias), 1):\n",
        "                print(f'  [{i}] dist={dist:.2f} → {doc[:90]}...')\n",
        "\n",
        "        # 2. Construir mensaje con RAG\n",
        "        prompt_con_contexto = self.construir_prompt(pregunta, docs)\n",
        "\n",
        "        # 3. Mantener historial para conversación multi-turno\n",
        "        self.historial.append({'role': 'user', 'content': prompt_con_contexto})\n",
        "\n",
        "        # 4. Llamar a Mistral AI\n",
        "        try:\n",
        "            respuesta_api = self.client.chat.complete(\n",
        "                model=self.modelo_mistral,\n",
        "                messages=[\n",
        "                    {'role': 'system', 'content': self.system_prompt},\n",
        "                    *self.historial\n",
        "                ]\n",
        "            )\n",
        "            respuesta_texto = respuesta_api.choices[0].message.content\n",
        "\n",
        "        except Exception as e:\n",
        "            respuesta_texto = f'❌ Error al llamar a Mistral: {e}'\n",
        "\n",
        "        # 5. Agregar respuesta al historial\n",
        "        self.historial.append({'role': 'assistant', 'content': respuesta_texto})\n",
        "\n",
        "        if verbose:\n",
        "            print(f'\\n🤖 Mistral responde:\\n{respuesta_texto}')\n",
        "\n",
        "        return respuesta_texto\n",
        "\n",
        "    def resetear_historial(self):\n",
        "        \"\"\"Limpia la conversación para empezar de nuevo\"\"\"\n",
        "        self.historial = []\n",
        "        print('🔄 Historial de conversación reseteado')\n",
        "\n",
        "\n",
        "# ── Instanciar el bot ──\n",
        "bot = BotRAGMistral(\n",
